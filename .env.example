# Root .env — copy to .env and fill in values. Auto-loaded by the
# Makefile (single root .env, scenario-agnostic).
#
#  cp .env.example .env
#  edit .env

# ---- AWS ----
# Profile name in ~/.aws/credentials. Picked up by the terraform AWS
# provider automatically (no terraform code reads this — env-only).
AWS_PROFILE=gtmlab

# AWS region. Picked up by the AWS provider; also used by ansible roles
# that need to know the region.
AWS_DEFAULT_REGION=eu-west-2

# ---- SSH key ----
# Name of the AWS key-pair (must already exist in AWS under AWS_PROFILE).
# The matching private key must live at ~/.ssh/${SSH_KEY_NAME}.pem
# with mode 0600. Both terraform (EC2 key_name + ssh_config emission)
# and ansible (private_key_file) use this.
SSH_KEY_NAME=ndelma-gtm-202504091000

# ---- Docker Hub ----
# Used to create dockerhub-secret in mojaloop / dfsps / k6-test /
# monitoring namespaces, so app pods can pull from Docker Hub without
# rate-limiting.
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_EMAIL=

# ---- MySQL ----
# Root password for the example-mojaloop-backend MySQL StatefulSet.
# Must match common/backend.yaml's primary.auth.rootPassword.
# (Cleanup TODO: drop the YAML hardcoding and inject via --set.)
MYSQL_ROOT_PASSWORD=db_password
